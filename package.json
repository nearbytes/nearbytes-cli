{
  "name": "nearbytes-cli",
  "version": "0.1.0",
  "description": "Nearbytes CLI consuming files, chat, skeleton, and sync packages",
  "type": "module",
  "bin": {
    "nbf": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "nbf": "tsc && node dist/cli/index.js",
    "repl": "tsc && node dist/cli/index.js",
    "dev": "yarn install && yarn repl --dev-inspect"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nearbytes-chat": "github:nearbytes/nearbytes-chat#046f5db1f6c93b32ab4def35f6388e445bd625d1",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto#6859719510764702844882b8488b35ab31f20145",
    "nearbytes-files": "github:nearbytes/nearbytes-files#b0bc2d2b020a4c2e3a13f8f79ed0eade8103fc98",
    "nearbytes-log": "github:nearbytes/nearbytes-log#0dc0519007bc1f8a9bfc3c52922387cc45fb7162",
    "nearbytes-skeleton": "github:nearbytes/nearbytes-skeleton#0158931decd927508d1532e8c3ed7c9dcee2825a",
    "nearbytes-sync": "github:nearbytes/nearbytes-sync#3585fb66fe2bd6ed4b59036f63b46c1af1083df3",
    "selfsigned": "^5.5.0",
    "nearbytes-engine": "github:nearbytes/nearbytes-engine"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/selfsigned": "^2.1.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
