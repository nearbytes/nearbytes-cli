{
  "name": "nearbytes-cli",
  "version": "0.1.0",
  "description": "Nearbytes CLI consuming files, chat, skeleton, and sync packages",
  "type": "module",
  "bin": {
    "nbf": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "engines:check": "node scripts/ensure-engines.mjs",
    "prepack": "node scripts/ensure-engines.mjs && tsc",
    "build": "node scripts/ensure-engines.mjs && tsc",
    "type-check": "tsc --noEmit",
    "refresh": "node scripts/refresh.mjs",
    "nbf": "node scripts/run-cli.mjs",
    "repl": "node scripts/run-cli.mjs",
    "dev": "node scripts/dev-bootstrap.mjs && node scripts/run-cli.mjs --dev-inspect",
    "dev:fast": "node scripts/run-cli.mjs --dev-inspect"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nearbytes-chat": "github:nearbytes/nearbytes-chat",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-engine": "https://github.com/nearbytes/nearbytes-engine.git#commit=81dc595fc644fd0a516c2d9b35e980bda0e3ac04",
    "nearbytes-files": "https://github.com/nearbytes/nearbytes-files.git#commit=00f04ba023bae4faf500614816ffcaf6f503a886",
    "nearbytes-log": "https://github.com/nearbytes/nearbytes-log.git#commit=0a1bef159ead34b542d20af74b8473e2232a90e2",
    "nearbytes-skeleton": "https://github.com/nearbytes/nearbytes-skeleton.git#commit=85b6287c9c8709a4c3382c83a941dce0632d3f20",
    "nearbytes-sync": "https://github.com/nearbytes/nearbytes-sync.git#commit=ec7203e8c1c7a8d6e1f235d1da76ba3c6ce6fb8e",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/selfsigned": "^2.1.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
