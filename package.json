{
  "name": "nearbytes-cli",
  "version": "0.1.0",
  "description": "Nearbytes CLI consuming files, chat, skeleton, and sync packages",
  "type": "module",
  "bin": {
    "nbf": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "tsc",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "refresh": "node scripts/refresh.mjs",
    "nbf": "tsc && node dist/cli/index.js",
    "repl": "tsc && node dist/cli/index.js",
    "dev": "node scripts/dev-bootstrap.mjs && yarn repl --dev-inspect",
    "dev:fast": "yarn repl --dev-inspect"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nearbytes-chat": "github:nearbytes/nearbytes-chat",
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-engine": "github:nearbytes/nearbytes-engine",
    "nearbytes-files": "github:nearbytes/nearbytes-files",
    "nearbytes-log": "github:nearbytes/nearbytes-log",
    "nearbytes-skeleton": "github:nearbytes/nearbytes-skeleton",
    "nearbytes-sync": "github:nearbytes/nearbytes-sync",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/selfsigned": "^2.1.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
